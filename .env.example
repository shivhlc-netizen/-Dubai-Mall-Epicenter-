# ── REQUIRED FOR NETLIFY DEPLOY ──
NEXTAUTH_SECRET=generate-a-32-char-random-string-here
NEXTAUTH_URL=https://your-site-name.netlify.app

# ── OPTIONAL: Google Gemini AI (free tier available) ──
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_RPM_LIMIT=15

# ── OPTIONAL: Google OAuth (for login with Google) ──
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── DISABLED IN DEMO MODE (kept for future use) ──
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=dubai_mall

# ── DISABLED IN DEMO MODE ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# ── DISABLED IN DEMO MODE ──
# ANTHROPIC_API_KEY=your-claude-api-key
# NETLIFY_BUILD_HOOK=your-build-hook-url
# CRON_SECRET=your-cron-secret
