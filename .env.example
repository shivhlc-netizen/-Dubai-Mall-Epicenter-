# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=dubai_mall_user
DB_PASSWORD=your_strong_password_here
DB_NAME=dubai_mall
# Set to true if your host requires SSL (PlanetScale, Railway, etc.)
DB_SSL=false

# ── NextAuth ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace_with_64_char_random_hex
NEXTAUTH_URL=http://localhost:5001

# ── Google OAuth ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Admin seed (used by database/seed.js only) ─────────────
ADMIN_EMAIL=admin@dubaimall.ae
ADMIN_PASSWORD=Admin@Dubai2025!

ANTHROPIC_API_KEY=your_anthropic_api_key_here
